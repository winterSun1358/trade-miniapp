/**app.wxss**/

/* 全局变量 */
page {
  --primary: #ff6b6b;
  --primary-dark: #ee5a5a;
  --secondary: #4ecdc4;
  --text: #333333;
  --text-secondary: #666666;
  --text-light: #999999;
  --bg: #f5f5f5;
  --bg-white: #ffffff;
  --border: #e5e5e5;
  --shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
  background-color: var(--bg);
  color: var(--text);
}

/* 通用容器 */
.container {
  padding: 20rpx;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background: var(--bg-white);
  border-radius: 16rpx;
  box-shadow: var(--shadow);
  margin-bottom: 20rpx;
  overflow: hidden;
}

/* Flex 布局 */
.flex {
  display: flex;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-wrap {
  flex-wrap: wrap;
}

/* 文字省略 */
.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ellipsis-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 价格样式 */
.price {
  color: var(--primary);
  font-weight: bold;
}

.price::before {
  content: '¥';
  font-size: 0.8em;
  margin-right: 2rpx;
}

.original-price {
  color: var(--text-light);
  text-decoration: line-through;
  font-size: 0.85em;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  background: rgba(255, 107, 107, 0.1);
  color: var(--primary);
}

.tag-secondary {
  background: rgba(78, 205, 196, 0.1);
  color: var(--secondary);
}

/* 按钮样式 */
.btn {
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  text-align: center;
  border: none;
}

.btn-primary {
  background: var(--primary);
  color: #fff;
}

.btn-primary:active {
  background: var(--primary-dark);
}

.btn-outline {
  background: transparent;
  border: 2rpx solid var(--primary);
  color: var(--primary);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  color: var(--text-light);
}

.empty-state text {
  margin-top: 20rpx;
  font-size: 28rpx;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--border);
  margin: 20rpx 0;
}

/* 安全区域 */
.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
