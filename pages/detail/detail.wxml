<!-- 商品详情页 -->
<view class="page-detail">
  <!-- 商品图片轮播 -->
  <swiper class="goods-swiper" indicator-dots circular current="{{swiperCurrent}}" bindchange="onSwiperChange">
    <swiper-item wx:for="{{goods.images}}" wx:key="*this">
      <view class="swiper-item-wrap" bindtap="previewImage" data-index="{{index}}">
        <image class="goods-swiper-image" src="{{item}}" mode="aspectFill" binderror="onImageError" data-index="{{index}}" />
        <view class="swiper-image-placeholder" wx:if="{{imageErrors[index]}}">
          <text>📷</text>
        </view>
      </view>
    </swiper-item>
  </swiper>

  <!-- 商品基本信息 -->
  <view class="info-section card">
    <view class="price-row">
      <text class="price">{{goods.price}}</text>
      <text class="original-price">{{goods.originalPrice}}</text>
      <text class="status-tag {{goods.status === '在售' ? 'on-sale' : 'sold'}}">{{goods.status}}</text>
    </view>

    <text class="goods-title">{{goods.title}}</text>

    <view class="goods-tags">
      <text class="tag">{{goods.condition}}</text>
      <text class="tag tag-secondary">{{goods.categoryName}}</text>
    </view>

    <view class="meta-list">
      <view class="meta-item">
        <text class="meta-label">📍 交易地点</text>
        <text class="meta-value">{{goods.location}}</text>
      </view>
      <view class="meta-item">
        <text class="meta-label">👤 发布者</text>
        <text class="meta-value">{{goods.publisher}}</text>
      </view>
      <view class="meta-item">
        <text class="meta-label">🕐 发布时间</text>
        <text class="meta-value">{{goods.publishTime}}</text>
      </view>
    </view>
  </view>

  <!-- 商品描述 -->
  <view class="desc-section card">
    <view class="section-title">商品描述</view>
    <text class="desc-content">{{goods.description}}</text>
  </view>

  <!-- 联系方式 -->
  <view class="contact-section card">
    <view class="section-title">联系方式</view>
    <view class="contact-item">
      <text class="contact-label">联系方式：</text>
      <text class="contact-value">{{goods.contact}}</text>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <view class="action-btn favorite-btn" bindtap="toggleFavorite">
      <text class="action-icon">{{isFavorite ? '❤️' : '🤍'}}</text>
      <text class="action-text">{{isFavorite ? '已收藏' : '收藏'}}</text>
    </view>

    <view class="action-btn wishlist-btn" bindtap="toggleWishlist">
      <text class="action-icon">{{isWishlist ? '✅' : '📋'}}</text>
      <text class="action-text">{{isWishlist ? '已加入' : '意向清单'}}</text>
    </view>

    <view class="contact-btn" bindtap="copyContact">
      <text>复制联系方式</text>
    </view>
  </view>
</view>
