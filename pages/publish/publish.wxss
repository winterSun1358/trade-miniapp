/** 发布页样式 **/
.page-publish {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 40rpx;
}

.form-container {
  padding: 20rpx;
}

.form-item {
  background: var(--bg-white);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 30rpx;
  color: var(--text);
  font-weight: bold;
  margin-bottom: 16rpx;
}

.required {
  color: var(--primary);
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: var(--bg);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--text);
  box-sizing: border-box;
}

.price-input-wrapper {
  display: flex;
  align-items: center;
  background: var(--bg);
  border-radius: 12rpx;
  padding: 0 24rpx;
}

.price-symbol {
  font-size: 32rpx;
  color: var(--primary);
  font-weight: bold;
  margin-right: 8rpx;
}

.price-input {
  flex: 1;
  background: transparent;
  padding: 0;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 80rpx;
  background: var(--bg);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--text);
}

.form-picker.placeholder {
  color: var(--text-light);
}

.picker-arrow {
  color: var(--text-light);
  font-size: 28rpx;
}

.form-textarea {
  width: 100%;
  height: 240rpx;
  background: var(--bg);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--text);
  box-sizing: border-box;
}

.textarea-count {
  text-align: right;
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 8rpx;
}

.tips {
  padding: 20rpx;
  text-align: center;
}

.tips text {
  font-size: 26rpx;
  color: var(--text-light);
}

/* 图片选择器 */
.image-picker {
  width: 100%;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.image-remove {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  border-radius: 50%;
  text-align: center;
  line-height: 36rpx;
  font-size: 24rpx;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  background: var(--bg);
  border: 2rpx dashed #ccc;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-icon {
  font-size: 60rpx;
  color: #ccc;
  line-height: 1;
}

.add-text {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 提交按钮 */
.submit-section {
  padding: 20rpx 40rpx;
}

.submit-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  background: var(--primary);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 45rpx;
  border: none;
}

.submit-btn::after {
  border: none;
}

.submit-btn.disabled {
  background: #ccc;
}

.submit-btn:not(.disabled):active {
  background: var(--primary-dark);
}
