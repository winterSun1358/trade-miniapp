<!-- 我的页面 -->
<view class="page-profile">
  <!-- 用户信息 -->
  <view class="user-section">
    <view class="user-info">
      <view class="avatar-wrap" bindtap="changeAvatar">
        <image class="user-avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
        <view class="avatar-overlay">
          <text class="avatar-edit-icon">📷</text>
        </view>
      </view>
      <view class="user-meta" bindtap="editNickname">
        <text class="user-name">{{userInfo.nickName}}</text>
        <text class="user-id">点击修改昵称</text>
      </view>
      <text class="edit-hint">✏️</text>
    </view>
  </view>

  <!-- 数据统计 -->
  <view class="stats-section card">
    <view class="stats-item" bindtap="switchTab" data-tab="favorites">
      <text class="stats-num">{{stats.favorites}}</text>
      <text class="stats-label">收藏</text>
    </view>
    <view class="stats-item" bindtap="switchTab" data-tab="history">
      <text class="stats-num">{{stats.history}}</text>
      <text class="stats-label">浏览</text>
    </view>
    <view class="stats-item" bindtap="switchTab" data-tab="publishes">
      <text class="stats-num">{{stats.publishes}}</text>
      <text class="stats-label">发布</text>
    </view>
    <view class="stats-item" bindtap="switchTab" data-tab="wishlist">
      <text class="stats-num">{{stats.wishlist}}</text>
      <text class="stats-label">意向</text>
    </view>
  </view>

  <!-- 内容区域 -->
  <view class="content-section">
    <!-- Tab 切换 -->
    <view class="tab-bar">
      <view
        class="tab-item {{currentTab === 'favorites' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="favorites"
      >
        收藏商品
      </view>
      <view
        class="tab-item {{currentTab === 'history' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="history"
      >
        浏览历史
      </view>
      <view
        class="tab-item {{currentTab === 'publishes' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="publishes"
      >
        我的发布
      </view>
      <view
        class="tab-item {{currentTab === 'wishlist' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="wishlist"
      >
        意向清单
      </view>
    </view>

    <!-- 商品列表 -->
    <scroll-view class="goods-scroll" scroll-y wx:if="{{goodsList.length > 0}}">
      <view class="goods-list">
        <view
          class="goods-item"
          wx:for="{{goodsList}}"
          wx:key="id"
        >
          <view class="goods-content" bindtap="goToDetail" data-id="{{item.id}}">
            <image class="goods-image" src="{{item.images[0]}}" mode="aspectFill" />
            <view class="goods-info">
              <text class="goods-title ellipsis">{{item.title}}</text>
              <view class="goods-tags">
                <text class="tag">{{item.condition}}</text>
              </view>
              <view class="goods-price-row">
                <text class="price">{{item.price}}</text>
                <text class="goods-status {{item.status === '在售' ? 'on-sale' : 'sold'}}">{{item.status}}</text>
              </view>
            </view>
          </view>

          <!-- 操作按钮 -->
          <view class="goods-actions">
            <view
              class="action-btn remove-btn"
              wx:if="{{currentTab === 'favorites'}}"
              bindtap="removeFavorite"
              data-id="{{item.id}}"
            >
              取消收藏
            </view>
            <view
              class="action-btn remove-btn"
              wx:if="{{currentTab === 'history'}}"
              bindtap="removeHistory"
              data-id="{{item.id}}"
            >
              删除记录
            </view>
            <view
              class="action-btn remove-btn"
              wx:if="{{currentTab === 'publishes'}}"
              bindtap="deletePublish"
              data-id="{{item.id}}"
            >
              删除发布
            </view>
            <view
              class="action-btn remove-btn"
              wx:if="{{currentTab === 'wishlist'}}"
              bindtap="removeWishlist"
              data-id="{{item.id}}"
            >
              移出清单
            </view>
          </view>
        </view>
      </view>
    </scroll-view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{goodsList.length === 0}}">
      <text>{{emptyIcon}}</text>
      <text>{{emptyText}}</text>
    </view>
  </view>

  <!-- 清除缓存按钮 -->
  <view class="clear-section">
    <view class="clear-btn" bindtap="clearAllCache">
      <text>🗑️ 清除所有缓存数据</text>
    </view>
  </view>
</view>
