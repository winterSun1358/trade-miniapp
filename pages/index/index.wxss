/** 首页样式 **/
.page-home {
  display: flex;
  flex-direction: column;
  height: 100vh;
  overflow: hidden;
  background: var(--bg);
}

/* 搜索栏 */
.search-section {
  padding: 20rpx;
  background: var(--bg-white);
}

.search-bar {
  display: flex;
  align-items: center;
  background: var(--bg);
  border-radius: 40rpx;
  padding: 12rpx 24rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text);
}

.search-btn {
  font-size: 28rpx;
  color: var(--primary);
  padding: 4rpx 16rpx;
  margin-left: 12rpx;
}

/* 轮播图 */
.banner-swiper {
  height: 300rpx;
  margin: 0 20rpx 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.banner-wrap {
  width: 100%;
  height: 100%;
  position: relative;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-title {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx 20rpx 20rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.6));
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

/* 分类 */
.category-section {
  margin: 0 20rpx 20rpx;
  padding: 20rpx;
}

.category-list {
  display: flex;
  justify-content: space-around;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx;
  border-radius: 12rpx;
  transition: all 0.3s;
}

.category-item.active {
  background: rgba(255, 107, 107, 0.1);
}

.category-item.active .category-name {
  color: var(--primary);
  font-weight: bold;
}

.category-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.category-name {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  padding: 16rpx 20rpx;
  background: var(--bg-white);
  margin: 0 20rpx 20rpx;
  border-radius: 12rpx;
}

.filter-item {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: var(--text-secondary);
  padding: 8rpx 0;
  position: relative;
}

.filter-item.active {
  color: var(--primary);
  font-weight: bold;
}

.filter-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: var(--primary);
  border-radius: 2rpx;
}

/* 商品列表 */
.goods-list {
  flex: 1;
  min-height: 0;
}

.goods-inner {
  padding: 0 16rpx 16rpx;
  box-sizing: border-box;
}

.goods-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx;
  color: var(--text-light);
  font-size: 26rpx;
}

/* 空状态 */
.empty-state {
  padding-top: 200rpx;
}

.empty-state text:first-child {
  font-size: 80rpx;
}
