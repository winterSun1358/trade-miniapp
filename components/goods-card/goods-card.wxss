/** 商品卡片组件 **/
.goods-card {
  background: var(--bg-white);
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: var(--shadow);
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100%;
}

.goods-image {
  width: 100%;
  height: 240rpx;
  flex-shrink: 0;
  background: #f0f0f0;
}

.goods-image-placeholder {
  width: 100%;
  height: 240rpx;
  flex-shrink: 0;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.goods-image-placeholder text {
  font-size: 60rpx;
}

.goods-info {
  padding: 12rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.goods-title {
  font-size: 26rpx;
  color: var(--text);
  line-height: 1.4;
  margin-bottom: 6rpx;
  display: block;
  min-height: 72rpx;
}

.goods-tags {
  display: flex;
  gap: 6rpx;
  margin-bottom: auto;
  min-height: 30rpx;
}

.goods-price-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-top: 8rpx;
  margin-bottom: 4rpx;
}

.goods-meta {
  display: flex;
  justify-content: space-between;
  font-size: 20rpx;
  color: var(--text-light);
}

.goods-location {
  max-width: 60%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 文字省略 */
.ellipsis-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.tag {
  display: inline-block;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  background: rgba(255, 107, 107, 0.1);
  color: #ff6b6b;
}

.tag-secondary {
  background: rgba(78, 205, 196, 0.1);
  color: #4ecdc4;
}

.price {
  color: #ff6b6b;
  font-weight: bold;
  font-size: 30rpx;
}

.original-price {
  color: #999;
  text-decoration: line-through;
  font-size: 22rpx;
}
