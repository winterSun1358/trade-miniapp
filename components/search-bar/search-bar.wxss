/** 搜索栏组件 **/
.search-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: var(--bg-white);
}

.search-bar.fixed {
  position: sticky;
  top: 0;
  z-index: 100;
}

.search-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 12rpx 24rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.clear-btn {
  font-size: 28rpx;
  color: #999;
  padding: 4rpx 8rpx;
}

.cancel-btn {
  font-size: 28rpx;
  color: #ff6b6b;
  margin-left: 16rpx;
  white-space: nowrap;
}
